# -------------------------------------------------------------------
# Sample environment variables (copy to .env if you run services
# outside Docker Compose). Inside Docker Compose these values are
# injected automatically from docker-compose.yml.
# -------------------------------------------------------------------

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Catalog Service
CATALOG_MONGO_URI=mongodb://localhost:27017
CATALOG_DB_NAME=catalog_db
CATALOG_REST_PORT=8001
CATALOG_GRPC_PORT=50051

# Order Service
ORDER_MONGO_URI=mongodb://localhost:27017
ORDER_DB_NAME=order_db
ORDER_REST_PORT=8002
CATALOG_GRPC_ADDR=localhost:50051

# Payment Service
PAYMENT_MONGO_URI=mongodb://localhost:27017
PAYMENT_DB_NAME=payment_db
PAYMENT_REST_PORT=8003

# Notification Service
NOTIFICATION_MONGO_URI=mongodb://localhost:27017
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_REST_PORT=8004

# API Gateway
CATALOG_URL=http://localhost:8001
ORDER_URL=http://localhost:8002
PAYMENT_URL=http://localhost:8003
NOTIFICATION_URL=http://localhost:8004
JWT_SECRET=super-secret-demo-key-change-me
RATE_LIMIT_PER_MINUTE=60
GATEWAY_PORT=8000
