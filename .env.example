# -------------------------------------------------------------------
# Root docker-compose values (single integrated demo run)
# -------------------------------------------------------------------
JWT_SECRET=super-secret-demo-key-change-me
RATE_LIMIT_PER_MINUTE=60

# -------------------------------------------------------------------
# Per-service local run examples (create separate .env per service)
# -------------------------------------------------------------------

# services/catalog-service/.env
# MONGO_URI=mongodb://localhost:27017
# DB_NAME=catalog_db
# REST_PORT=8001
# GRPC_PORT=50051

# services/order-service/.env
# DATABASE_URL=postgresql+psycopg://order_user:order_password@localhost:5432/order_db
# CATALOG_GRPC_HOST=localhost
# CATALOG_GRPC_PORT=50051
# PAYMENT_SERVICE_URL=http://localhost:8003
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# RABBITMQ_EXCHANGE=ecom.events

# services/payment-service/.env
# PAYMENT_DB_HOST=localhost
# PAYMENT_DB_PORT=5432
# PAYMENT_DB_NAME=payment_db
# PAYMENT_DB_USER=payment_user
# PAYMENT_DB_PASSWORD=payment_password
# PORT=8003
# NODE_ENV=production

# services/notification-service/.env
# MONGO_URI=mongodb://localhost:27017
# DB_NAME=notification_db
# REST_PORT=8004
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# services/api-gateway/.env
# PORT=8000
# CATALOG_BASE_URL=http://localhost:8001
# ORDER_BASE_URL=http://localhost:8002
# PAYMENT_BASE_URL=http://localhost:8003
# NOTIFICATION_BASE_URL=http://localhost:8004
# JWT_SECRET=super-secret-demo-key-change-me
# RATE_LIMIT_PER_MINUTE=60
